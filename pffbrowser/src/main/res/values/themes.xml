<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="PbTheme.PffBrowser" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="CustomEditTextStyle" parent="Widget.AppCompat.EditText">
        <!-- 未聚焦时的下划线颜色 -->
        <item name="colorControlNormal">#999999</item> <!-- 灰色 -->
        <!-- 聚焦时的下划线颜色和光标颜色（通常跟随此属性） -->
        <item name="colorControlActivated">#FF0000</item> <!-- 红色 -->
        <!-- 或者使用 colorAccent，如果上面两个没定义，会回退到此颜色 -->
        <item name="colorAccent">#FF0000</item>
    </style>
</resources>
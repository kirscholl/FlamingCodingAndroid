<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <ImageView
        android:id="@+id/pb_iv_agent_avatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/pb_bg_agent_avatar"
        android:contentDescription="Agent头像"
        android:padding="8dp"
        android:src="@drawable/pb_ic_agent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#6200EE" />

    <TextView
        android:id="@+id/tv_agent_message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:background="@drawable/pb_bg_agent_message"
        android:elevation="2dp"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:textColor="#333333"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toEndOf="@id/pb_iv_agent_avatar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="280dp"
        tools:text="这是Agent的回复消息，可能会很长很长很长" />

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- 文件图标 -->
        <ImageView
            android:id="@+id/ivFileIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:contentDescription="文件图标"
            tools:src="@drawable/pb_ic_file_unknown" />

        <!-- 文件名 -->
        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintTop_toTopOf="@id/ivFileIcon"
            app:layout_constraintStart_toEndOf="@id/ivFileIcon"
            app:layout_constraintEnd_toStartOf="@id/btnAction"
            android:textSize="16sp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="example_document.pdf" />

        <!-- 文件大小和状态 -->
        <TextView
            android:id="@+id/tvFileInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvFileName"
            app:layout_constraintStart_toEndOf="@id/ivFileIcon"
            app:layout_constraintEnd_toEndOf="parent"
            android:textSize="12sp"
            android:textColor="#757575"
            tools:text="1.5 MB · 已完成" />

        <!-- 进度条 -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_marginStart="12dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvFileInfo"
            app:layout_constraintStart_toEndOf="@id/ivFileIcon"
            app:layout_constraintEnd_toEndOf="parent"
            android:max="100"
            tools:progress="65" />

        <!-- 下载速度和进度百分比 -->
        <TextView
            android:id="@+id/tvProgress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/progressBar"
            app:layout_constraintStart_toEndOf="@id/ivFileIcon"
            app:layout_constraintEnd_toEndOf="parent"
            android:textSize="12sp"
            android:textColor="#999999"
            tools:text="65% · 1.2 MB/s" />

        <!-- 操作按钮 -->
        <ImageButton
            android:id="@+id/btnAction"
            android:layout_width="40dp"
            android:layout_height="40dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="操作按钮"
            tools:src="@android:drawable/ic_media_pause" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>

